# LLM Configuration
# LLM_PROVIDER can be 'ollama' or 'vertex'
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# Vertex AI Configuration (only required if LLM_PROVIDER=vertex)
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1

# MongoDB Configuration
MONGO_URI=mongodb://root:example@localhost:27017/?directConnection=true
MONGO_DB_NAME=madrid_events
MONGO_COLLECTION_NAME=events
